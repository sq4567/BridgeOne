<ui:FluentWindow x:Class="BridgeOne.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                xmlns:local="clr-namespace:BridgeOne"
                mc:Ignorable="d"
                Title="BridgeOne" Height="520" Width="800"
                WindowStartupLocation="CenterScreen"
                ExtendsContentIntoTitleBar="True"
                WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <DockPanel Background="Transparent">
        <!-- ==================== 커스텀 타이틀 바 ==================== -->
        <Grid DockPanel.Dock="Top" Height="40" Background="Transparent" MouseDown="TitleBar_MouseDown">
            <TextBlock Text="BridgeOne"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />

            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Margin="0,0,8,0">
                <!-- 최소화 버튼 -->
                <Button Name="MinimizeButton"
                        Width="40" Height="40"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="MinimizeButton_Click"
                        Cursor="Hand">
                    <TextBlock Text="&#x2212;" FontSize="18" Foreground="#FFFFFF" FontWeight="Bold" />
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1A1A1A" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 최대화 버튼 -->
                <Button Name="MaximizeButton"
                        Width="40" Height="40"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="MaximizeButton_Click"
                        Cursor="Hand"
                        Margin="4,0,0,0">
                    <TextBlock Name="MaximizeIcon" Text="&#x2610;" FontSize="14" Foreground="#FFFFFF" FontWeight="Bold" />
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1A1A1A" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 종료 버튼 -->
                <Button Name="CloseButton"
                        Width="40" Height="40"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        Cursor="Hand"
                        Margin="4,0,0,0">
                    <TextBlock Text="&#x2715;" FontSize="16" Foreground="#FFFFFF" FontWeight="Bold" />
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#C60000" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ==================== 하단 상태 바 ==================== -->
        <Border DockPanel.Dock="Bottom" Background="#2D2D30" Height="32" Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 상태 표시 점 -->
                <Ellipse Width="8" Height="8"
                         Fill="{Binding Connection.StatusBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0" />
                <!-- 상태 텍스트 -->
                <TextBlock Text="{Binding Connection.StatusText}"
                           FontSize="12"
                           Foreground="#CCCCCC"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ==================== 메인 컨텐츠 영역 ==================== -->
        <Grid Margin="16,8,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ===== 연결 상태 카드 ===== -->
            <Border Grid.Row="0"
                    Background="#2D2D30"
                    CornerRadius="8"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 좌측: 상태 정보 -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <!-- 상태 헤더 (아이콘 + 텍스트) -->
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="14" Height="14"
                                     Fill="{Binding Connection.StatusBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0">
                                <!-- Connecting 상태에서 깜빡임 애니메이션 -->
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Connection.IsConnecting}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="BlinkStoryboard">
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="Opacity"
                                                                From="1.0" To="0.25"
                                                                Duration="0:0:0.6"
                                                                AutoReverse="True"
                                                                RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="BlinkStoryboard" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding Connection.StatusText}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- 장치 정보 (연결 시에만 표시) -->
                        <StackPanel Margin="24,6,0,0"
                                    Visibility="{Binding Connection.IsDeviceInfoVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="13" Foreground="#CCCCCC">
                                <Run Text="COM 포트: " />
                                <Run Text="{Binding Connection.ComPort, Mode=OneWay}" FontWeight="Medium" />
                            </TextBlock>
                            <TextBlock Text="{Binding Connection.DeviceDescription}"
                                       FontSize="13"
                                       Foreground="#999999"
                                       Margin="0,2,0,0" />

                            <!-- ESP32 모드 표시 -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Ellipse Width="10" Height="10"
                                         Fill="{Binding Connection.ModeBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Connection.ModeDisplayText}"
                                           FontSize="13"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- 활성 기능 목록 (Standard 모드에서만 표시) -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                        Visibility="{Binding Connection.IsActiveFeaturesVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="기능: "
                                           FontSize="12"
                                           Foreground="#999999" />
                                <TextBlock Text="{Binding Connection.ActiveFeaturesText}"
                                           FontSize="12"
                                           Foreground="#10B981" />
                            </StackPanel>

                            <!-- RTT 표시 -->
                            <TextBlock Text="{Binding Connection.RttDisplayText}"
                                       FontSize="13"
                                       Foreground="#999999"
                                       Margin="0,2,0,0" />

                            <!-- 연결 품질 표시 -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="품질: "
                                           FontSize="13"
                                           Foreground="#999999" />
                                <TextBlock Text="{Binding Connection.QualityDisplayText}"
                                           FontSize="13"
                                           Foreground="{Binding Connection.QualityBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 재연결 진행 중 메시지 (재연결 시도 중에만 표시) -->
                        <TextBlock Text="{Binding Connection.ReconnectStatusText}"
                                   FontSize="13"
                                   Foreground="#F59E0B"
                                   Margin="24,6,0,0"
                                   Visibility="{Binding Connection.IsReconnecting, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- 우측: 버튼 그룹 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- PING 테스트 버튼 -->
                        <Button Content="PING 테스트"
                                Command="{Binding Connection.SendPingCommand}"
                                Padding="16,8"
                                FontSize="14"
                                Cursor="Hand"
                                Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="PingBorder"
                                                        Background="#1A6B35"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}"
                                                        BorderThickness="1"
                                                        BorderBrush="#2D8A4E">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="PingBorder" Property="Background" Value="#228B44" />
                                                        <Setter TargetName="PingBorder" Property="BorderBrush" Value="#34A85A" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="PingBorder" Property="Background" Value="#155D2B" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="PingBorder" Property="Background" Value="#2A2A2A" />
                                                        <Setter TargetName="PingBorder" Property="BorderBrush" Value="#3A3A3A" />
                                                        <Setter Property="Foreground" Value="#666666" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- 연결/해제 버튼 -->
                        <Button Content="{Binding Connection.ToggleButtonText}"
                                Command="{Binding Connection.ToggleConnectionCommand}"
                                Padding="20,8"
                                FontSize="14"
                                Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                    Background="#3C3C3C"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}"
                                                    BorderThickness="1"
                                                    BorderBrush="#555555">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#505050" />
                                                    <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#666666" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#383838" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="ButtonBorder" Property="Background" Value="#2A2A2A" />
                                                    <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3A3A3A" />
                                                    <Setter Property="Foreground" Value="#666666" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== 디버그 로그 ===== -->
            <Border Grid.Row="1"
                    Background="#2D2D30"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 헤더: 타이틀 + 지우기 버튼 -->
                    <DockPanel Grid.Row="0">
                        <TextBlock Text="디버그 로그"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#CCCCCC"
                                   VerticalAlignment="Center" />
                        <Button Content="복사"
                                Command="{Binding Connection.CopyDebugLogCommand}"
                                HorizontalAlignment="Right"
                                Cursor="Hand"
                                Padding="10,3"
                                FontSize="12"
                                Margin="0,0,4,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="#999999" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="CopyBorder"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CopyBorder" Property="Background" Value="#3C3C3C" />
                                                        <Setter Property="Foreground" Value="#CCCCCC" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="지우기"
                                Command="{Binding Connection.ClearDebugLogCommand}"
                                HorizontalAlignment="Right"
                                Cursor="Hand"
                                Padding="10,3"
                                FontSize="12">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="#999999" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ClearBorder"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ClearBorder" Property="Background" Value="#3C3C3C" />
                                                        <Setter Property="Foreground" Value="#CCCCCC" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DockPanel>

                    <!-- 로그 출력 영역 -->
                    <TextBox x:Name="DebugLogTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Text="{Binding Connection.DebugLog, Mode=OneWay}"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="#999999"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,8,0,0"
                             TextChanged="DebugLogTextBox_TextChanged" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</ui:FluentWindow>
